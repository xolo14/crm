# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and loaded by Vite alongside .env.

# PHP backend (login, leads, batches, payment links, etc.)
# Leave empty or unset = same-origin /api (recommended for Hostinger).
# Do NOT set to the site root only (e.g. https://crm.example.com) — use /api or leave blank.
VITE_API_URL=

# Razorpay publishable key (Key ID only — never put the secret on the client).
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE

# Payment Links API secret keys go in api/config.php on the server (PHP only — no Node.js):
#   RAZORPAY_KEY_ID=rzp_test_xxx or rzp_live_xxx
#   RAZORPAY_KEY_SECRET=your_secret
#   RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
#   CRM_PUBLIC_URL=https://your-crm-domain.com
#   RAZORPAY_WEBHOOK_SECRET=whsec_xxx
# Razorpay Dashboard → Webhooks → URL: https://your-crm-domain.com/api/payment-links.php?action=webhook
# Events: payment_link.paid, payment_link.partially_paid
