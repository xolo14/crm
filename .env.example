# Local development only — production Hostinger deploy does NOT use these.
# Production build reads .env.production (VITE_API_URL= → same-origin /api).

# PHP backend runs on Hostinger in api/config.php (not env vars).
# Leave empty = same-origin /api (recommended for Hostinger).
VITE_API_URL=

# Razorpay publishable key (Key ID only — secret stays in api/config.php on server).
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE

# Optional local dev — Google Sign-In (server also needs GOOGLE_CLIENT_ID in api/config.php)
# VITE_GOOGLE_CLIENT_ID=

# Optional local dev — Google Sign-In (server also needs GOOGLE_CLIENT_ID in api/config.php)
#   RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET
#   CRM_PUBLIC_URL=  (leave empty — auto-detects your domain)
# Razorpay Dashboard → Webhooks → https://your-domain.com/api/payment-links.php?action=webhook
