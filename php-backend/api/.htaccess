RewriteEngine On

# Block sensitive config / schema from direct HTTP access
<FilesMatch "^(config\.php|config\.example\.php|\.env|database\.sql|database\.mysql\.sql)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Let PHP handle OPTIONS preflight (cors() in helpers.php sets headers).
# Do NOT return 200 here without CORS headers — that breaks cross-origin API calls.

RewriteRule ^whatsapp/webhook/?$ whatsapp/webhook.php [L,QSA]
RewriteRule ^lead-ingest/?$ lead-ingest.php [L,QSA]

RewriteRule ^payment-links/?$ payment-links.php [L,QSA]
RewriteRule ^payment-links/create/?$ payment-links.php?action=create [L,QSA]
RewriteRule ^payment-links/webhook/?$ payment-links.php?action=webhook [L,QSA]
RewriteRule ^payment-links/([A-Za-z0-9_]+)/cancel/?$ payment-links.php?action=cancel&id=$1 [L,QSA]
RewriteRule ^payment-links/([A-Za-z0-9_]+)/remind/?$ payment-links.php?action=remind&id=$1 [L,QSA]
RewriteRule ^payment-links/([A-Za-z0-9_]+)/?$ payment-links.php?action=fetch&id=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
