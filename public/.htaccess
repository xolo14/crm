<IfModule mod_mime.c>
  AddType application/javascript js mjs
  AddType text/css css
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Block sensitive files from direct download (root + common names)
  <FilesMatch "^(\.env|\.git|database\.sql|database\.mysql\.sql|config\.php|config\.example\.php)$">
    <IfModule mod_authz_core.c>
      Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
      Order deny,allow
      Deny from all
    </IfModule>
  </FilesMatch>

  # Scanner / legacy paths — return 404 instead of SPA index.html (stops dirb false positives)
  RewriteRule ^~ - [R=404,L]
  RewriteRule ^(cgi-bin|scripts|administrator|wp-admin|wp-content|wp-includes|phpmyadmin|mysql|\.git|\.env|\.svn|\.hg)(/|$) - [R=404,L,NC]

  # Wrong-path fallback (when frontend called /payment-links.php without /api)
  RewriteRule ^payment-links\.php$ api/payment-links.php [L,QSA,NC]

  # ── PHP API: never route /api/*.php to the React app ─────────
  RewriteRule ^api/.+\.php$ - [L,NC]

  # Missing /api/*.php must not fall through to index.html (that causes "HTTP 200" HTML errors)
  RewriteCond %{REQUEST_URI} ^/api/.+\.php$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Vite build chunks — never SPA-fallback (missing .js must 404, not return HTML)
  RewriteCond %{REQUEST_URI} ^/assets/ [NC]
  RewriteRule ^ - [R=404,L]

  # Other static extensions at site root
  RewriteCond %{REQUEST_URI} \.(js|mjs|css|woff2?|ttf|eot|ico|png|jpg|jpeg|webp|svg|gif|map)$ [NC]
  RewriteRule ^ - [R=404,L]

  # WhatsApp Meta webhook (pretty URL for App Dashboard callback)
  RewriteRule ^api/whatsapp/webhook/?$ api/whatsapp/webhook.php [L,QSA]

  # Pretty URLs for payment links (optional; .php URLs also work)
  RewriteRule ^api/payment-links/([^/]+)/cancel/?$ api/payment-links.php?action=cancel&id=$1 [L,QSA]
  RewriteRule ^api/payment-links/([^/]+)/remind/?$ api/payment-links.php?action=remind&id=$1 [L,QSA]
  RewriteRule ^api/payment-links/create/?$ api/payment-links.php?action=create [L,QSA]
  RewriteRule ^api/payment-links/webhook/?$ api/payment-links.php?action=webhook [L,QSA]
  RewriteRule ^api/payment-links/([^/]+)/?$ api/payment-links.php?action=fetch&id=$1 [L,QSA]
  RewriteRule ^api/payment-links/?$ api/payment-links.php [L,QSA]

  # Other /api/* paths (PHP files, uploads, etc.)
  RewriteRule ^api/ - [L]

  # SPA login portals (explicit for shared hosting)
  RewriteRule ^(sales_rep_portal|super_admin|admin|manager|marketing|hr-login|auth|privacy|terms)/?$ index.html [L]

  # React SPA — all other client routes
  RewriteRule ^ index.html [L]
</IfModule>

# Gzip/Brotli-style compression for HTML, CSS, JS (Hostinger mod_deflate)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/javascript application/json application/xml image/svg+xml
</IfModule>

# Security + cache headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https: wss:; frame-src https://www.facebook.com https://web.facebook.com; object-src 'none'; base-uri 'self'; form-action 'self'"

  <FilesMatch "\.(js|css|woff2?|ttf|eot|ico|png|jpg|jpeg|webp|svg|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html must revalidate on every load: hashed asset files are replaced on
  # each deploy, and a cached index.html pointing at deleted hashes white-screens
  # the app until the cache expires.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "^(robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
