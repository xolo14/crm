<IfModule mod_mime.c>
  AddType application/javascript js mjs
  AddType text/css css
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Block sensitive files from direct download
  <FilesMatch "^(\.env|\.git|database\.sql|config\.example\.php)$">
    Require all denied
  </FilesMatch>

  # Wrong-path fallback (when frontend called /payment-links.php without /api)
  RewriteRule ^payment-links\.php$ api/payment-links.php [L,QSA,NC]

  # ── PHP API: never route /api/*.php to the React app ─────────
  RewriteRule ^api/.+\.php$ - [L,NC]

  # Missing /api/*.php must not fall through to index.html (that causes "HTTP 200" HTML errors)
  RewriteCond %{REQUEST_URI} ^/api/.+\.php$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Vite build chunks — never SPA-fallback (missing .js must 404, not return HTML)
  RewriteCond %{REQUEST_URI} ^/assets/ [NC]
  RewriteRule ^ - [R=404,L]

  # Other static extensions at site root
  RewriteCond %{REQUEST_URI} \.(js|mjs|css|woff2?|ttf|eot|ico|png|jpg|jpeg|webp|svg|gif|map)$ [NC]
  RewriteRule ^ - [R=404,L]

  # Pretty URLs for payment links (optional; .php URLs also work)
  RewriteRule ^api/payment-links/([^/]+)/cancel/?$ api/payment-links.php?action=cancel&id=$1 [L,QSA]
  RewriteRule ^api/payment-links/([^/]+)/remind/?$ api/payment-links.php?action=remind&id=$1 [L,QSA]
  RewriteRule ^api/payment-links/create/?$ api/payment-links.php?action=create [L,QSA]
  RewriteRule ^api/payment-links/webhook/?$ api/payment-links.php?action=webhook [L,QSA]
  RewriteRule ^api/payment-links/([^/]+)/?$ api/payment-links.php?action=fetch&id=$1 [L,QSA]
  RewriteRule ^api/payment-links/?$ api/payment-links.php [L,QSA]

  # Other /api/* paths (PHP files, uploads, etc.)
  RewriteRule ^api/ - [L]

  # SPA login portals (explicit for shared hosting)
  RewriteRule ^(sales_rep_portal|super_admin|admin|manager|marketing|hr-login|auth)/?$ index.html [L]

  # React SPA — all other client routes
  RewriteRule ^ index.html [L]
</IfModule>

# Gzip/Brotli-style compression for HTML, CSS, JS (Hostinger mod_deflate)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache static assets (LCP / repeat visits)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot|ico|png|jpg|jpeg|webp|svg|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^(index\.html|robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
